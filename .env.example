# Optional: set these in your shell so per-command flags become
# optional. Source this from your shell rc, or use direnv.

# RPC endpoint of the target Ligate Chain network.
# Localnet:    http://127.0.0.1:12346
# devnet-1:    https://rpc.ligate.io
LIGATE_RPC=https://rpc.ligate.io

# ---------- Chain identity ----------
# These bind every state-changing call to a specific chain.

# Numeric chain id (u64), from the running chain's `chain_state.json`.
# NOT the same as the `chain_id` STRING `ligate-devnet-1`.
LIGATE_CHAIN_ID=

# 32-byte chain hash (64-char hex), from a running node's
# `/v1/rollup/info` endpoint. Binds tx signatures to the runtime
# composition.
LIGATE_CHAIN_HASH=

# `$LGT` token id (64-char hex), from `bank.json`'s `token_id` field
# at genesis.
LIGATE_LGT_TOKEN_ID=

# ---------- Faucet ----------
# Override the faucet base URL. Default `https://faucet.ligate.io`.
LIGATE_FAUCET_URL=https://faucet.ligate.io

# ---------- Tracing ----------
# Log level. Examples:
#   warn                          (default, quiet)
#   info,ligate=info              (basic operator visibility)
#   debug,reqwest=debug           (verbose for triage)
RUST_LOG=warn
